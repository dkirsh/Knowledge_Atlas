{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kirsh.atlas/cogs160/classifier_response.json",
  "$comment": "This schema describes the response shape after the Track-2 classifier-integration PR ships. Pre-merge responses (no `classifier` block, no `contract_version` field) validate against `classifier_response.legacy.json` instead. Validators MUST select the schema by inspecting the presence of `contract_version` at the top level — if absent, fall through to the legacy schema.",
  "title": "POST /api/articles/submit response (post-merge, contract v1.0)",
  "description": "Schema for the response returned by ka_article_endpoints.submit_articles after this PR. Existing fields are preserved; the new `classifier` sub-object is added on every item that reached the classifier stage.",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract_version", "submission_id", "items", "summary"],
  "properties": {
    "contract_version": {
      "type": "string",
      "const": "1.0"
    },
    "submission_id": {
      "type": "string",
      "pattern": "^KA-IN-\\d{6}$"
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/item" }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["total", "staged", "duplicates", "rejected"],
      "properties": {
        "total":      { "type": "integer", "minimum": 0 },
        "staged":     { "type": "integer", "minimum": 0 },
        "duplicates": { "type": "integer", "minimum": 0 },
        "rejected":   { "type": "integer", "minimum": 0 },
        "edge_cases": { "type": "integer", "minimum": 0 }
      }
    }
  },

  "$defs": {
    "item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "article_id",
        "input_mode",
        "validation_status",
        "duplicate_status",
        "metadata",
        "status"
      ],
      "properties": {
        "article_id": {
          "type": "string",
          "pattern": "^KA-ART-\\d{6}$"
        },
        "input_mode": {
          "type": "string",
          "enum": ["pdf_single", "citation_text"]
        },
        "filename":  { "type": "string", "maxLength": 255 },
        "citation":  { "type": "string", "maxLength": 200 },
        "validation_status": {
          "type": "string",
          "enum": ["valid", "invalid", "accepted"]
        },
        "duplicate_status": {
          "type": "string",
          "enum": ["not_checked", "not_duplicate", "duplicate"]
        },
        "duplicate_of": {
          "oneOf": [
            { "type": "null" },
            { "type": "string", "pattern": "^KA-ART-\\d{6}$" }
          ]
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "doi":        { "type": ["string", "null"], "maxLength": 200 },
            "confidence": { "type": ["string", "null"], "enum": ["low", "medium", "high", null] }
          }
        },
        "status": {
          "type": "string",
          "enum": [
            "staged_pending_review",
            "needs_review",
            "duplicate_existing",
            "rejected_bad_file",
            "rejected_off_topic"
          ]
        },
        "reason":   { "type": ["string", "null"], "maxLength": 200 },
        "a0_task":  { "type": ["string", "null"], "enum": ["task1", "task2", null] },
        "article_type": {
          "type": ["string", "null"],
          "enum": ["experimental", "review", "theory", "mechanism", "meta_analysis", "other", null]
        },
        "counts_toward_requirement": { "type": "boolean" },

        "classifier": { "$ref": "#/$defs/classifier_block" }
      },

      "allOf": [
        {
          "if": { "properties": { "status": { "const": "duplicate_existing" } }, "required": ["status"] },
          "then": { "required": ["duplicate_of"], "properties": { "duplicate_of": { "type": "string", "pattern": "^KA-ART-\\d{6}$" } } }
        },
        {
          "if": { "properties": { "status": { "enum": ["staged_pending_review", "needs_review", "rejected_off_topic"] } } },
          "then": { "required": ["classifier"] }
        }
      ]
    },

    "classifier_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "verdict",
        "classifier_article_type",
        "article_type_confidence",
        "primary_topic",
        "primary_topic_confidence",
        "active_topic_matches",
        "overall_confidence",
        "next_action",
        "backend"
      ],
      "properties": {
        "verdict": {
          "description": "Classifier's verdict for this paper. MAY be null only when the classifier ran on bibliographic-only evidence (stable_topic_routing is None on the classifier result); in that case the endpoint routes the item to Branch B (needs_review). For all other cases the verdict is one of accept | edge_case | reject.",
          "oneOf": [
            { "type": "null" },
            { "type": "string", "enum": ["accept", "edge_case", "reject"] }
          ]
        },
        "classifier_article_type": {
          "description": "Classifier's article-type verdict. Distinct from item.article_type, which is the submitter's self-reported A0 type.",
          "type": "string",
          "minLength": 1,
          "maxLength": 60
        },
        "article_type_confidence": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "primary_topic": {
          "type": ["string", "null"],
          "maxLength": 80
        },
        "primary_topic_confidence": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "active_topic_matches": {
          "type": "array",
          "maxItems": 10,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["topic", "score"],
            "properties": {
              "topic": { "type": "string", "maxLength": 80 },
              "score": { "type": "number", "minimum": 0.0, "maximum": 1.0 }
            }
          }
        },
        "overall_confidence": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "next_action": {
          "type": "string",
          "enum": [
            "ready_for_topic_routing",
            "ready_for_downstream_extraction",
            "review_borderline_case",
            "ready_for_intake_decision",
            "need_abstract_or_keywords",
            "extract_pdf_surface"
          ]
        },
        "backend": {
          "type": "string",
          "enum": ["atlas_shared", "ka_local_fallback"]
        }
      }
    }
  }
}
